<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F0F0F0"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Top Header Info -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/truck_icon_container"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#F0F7FF"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/iv_truck_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="12dp"
                    android:src="@drawable/ic_truck"
                    app:tint="#2196F3"
                    android:contentDescription="Truck Icon" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/truck_icon_container"
                android:layout_marginStart="14dp"
                android:layout_centerVertical="true"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_truck_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GT-001"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tv_plate_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABC 1234"
                    android:textSize="13sp"
                    android:textColor="#8E8E93" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="ACTIVE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#34C759"
                android:background="@drawable/bg_status_indicator"
                android:backgroundTint="#E8F5E9"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp" />
        </RelativeLayout>

        <!-- Main Details Grid -->
        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:columnCount="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Location"
                    android:textSize="11sp"
                    android:textColor="#8E8E93" />
                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Balintawak"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💨 Speed"
                    android:textSize="11sp"
                    android:textColor="#8E8E93" />
                <TextView
                    android:id="@+id/tv_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 km/h"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Driver"
                    android:textSize="11sp"
                    android:textColor="#8E8E93" />
                <TextView
                    android:id="@+id/tv_driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ricardo"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:textSize="14sp" />
            </LinearLayout>
        </GridLayout>

        <!-- Smart Analytics Dashboard (Glass Style) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:padding="12dp"
            android:background="@drawable/glass_card_bg"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛣️ DISTANCE"
                    android:textSize="9sp"
                    android:textColor="#8E8E93"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 km"
                    android:textStyle="bold"
                    android:textColor="#2196F3"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="#F0F0F0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⛽ FUEL"
                    android:textSize="9sp"
                    android:textColor="#8E8E93"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_fuel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0 L"
                    android:textStyle="bold"
                    android:textColor="#FF9500"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:layout_gravity="center_vertical"
                android:background="#F0F0F0" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛑 STOPS"
                    android:textSize="9sp"
                    android:textColor="#8E8E93"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_stops"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textStyle="bold"
                    android:textColor="#FF3B30"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Interactive Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_view_history"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="HISTORY"
                android:textColor="#48484A"
                android:textSize="13sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_location"
                app:iconSize="18dp"
                app:iconTint="#48484A"
                android:backgroundTint="#F2F2F7"
                app:cornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_optimize"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1.2"
                android:layout_marginStart="6dp"
                android:text="COMPARE PATH"
                android:textSize="13sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_navigation"
                app:iconSize="18dp"
                app:cornerRadius="16dp"
                android:backgroundTint="#34C759"
                android:textColor="@android:color/white" />
        </LinearLayout>

        <!-- Footer Meta -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_time"
                    app:tint="#8E8E93"
                    android:contentDescription="Time Icon" />
                <TextView
                    android:id="@+id/tv_last_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Updated just now"
                    android:textSize="11sp"
                    android:textColor="#8E8E93" />
            </LinearLayout>

            <TextView
                android:id="@+id/btn_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="ETA: --"
                android:textColor="#2196F3"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingVertical="4dp" />
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
