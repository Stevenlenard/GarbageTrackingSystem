<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:paddingVertical="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_truck_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Truck-001 (ABC-123)"
                android:textColor="#333333"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_truck_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Active • Fuel: 85%"
                android:textColor="#4CAF50"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_edit_truck"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_logo"
            android:backgroundTint="#E8F5E9"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#2E7D32" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_truck_active"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            app:thumbTint="@color/switch_thumb_selector"
            app:trackTint="@color/switch_track_selector" />
    </LinearLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F0F0F0" />
</LinearLayout>