<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyApplication" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your dark theme here. -->
        <item name="colorPrimary">@color/primary_blue</item>
        <item name="colorSecondary">@color/secondary_blue</item>
        <item name="colorTertiary">@color/teal_link</item>
        <!-- Remove purple selection/highlighting -->
        <item name="colorControlActivated">@color/black</item>
        <item name="colorControlHighlight">@color/light_gray</item>
        <item name="android:textColorHighlight">#40000000</item>
    </style>
</resources>