<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/truck_icon_container"
                android:layout_width="40dp"
                android:layout_height="40dp"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E3F2FD"
                app:strokeWidth="0dp">
                <ImageView
                    android:id="@+id/iv_truck_icon"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="10dp"
                    android:src="@drawable/ic_truck"
                    app:tint="#2196F3" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/truck_icon_container"
                android:layout_marginStart="12dp"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_truck_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GT-001"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/tv_plate_number"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ABC 1234"
                    android:textSize="12sp"
                    android:textColor="#757575" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_status_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="ACTIVE"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                android:background="@drawable/bg_status_indicator"
                android:backgroundTint="#E8F5E9"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 Location"
                    android:textSize="10sp"
                    android:textColor="#757575" />
                <TextView
                    android:id="@+id/tv_location"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Purok 2"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💨 Speed"
                    android:textSize="10sp"
                    android:textColor="#757575" />
                <TextView
                    android:id="@+id/tv_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="15 km/h"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👤 Driver"
                    android:textSize="10sp"
                    android:textColor="#757575" />
                <TextView
                    android:id="@+id/tv_driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pedro Santos"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F5F5F5" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:id="@+id/tv_last_update"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 Last Update: 15:06 PM"
                android:textSize="10sp"
                android:textColor="#9E9E9E"
                android:layout_centerVertical="true" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_eta"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="ETA: ~15 mins"
                android:textColor="#2196F3"
                android:textSize="10sp"
                android:textStyle="bold"
                app:rippleColor="#E3F2FD" />
        </RelativeLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
